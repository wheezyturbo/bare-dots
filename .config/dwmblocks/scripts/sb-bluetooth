#!/bin/sh
# sb-bluetooth â€” connected device, on, or off

powered=$(bluetoothctl show 2>/dev/null | grep "Powered:" | awk '{print $2}')

if [ "$powered" != "yes" ]; then
    printf "ó°‚˛"
    exit 0
fi

# Get connected device name
device=$(bluetoothctl devices Connected 2>/dev/null | head -1 | cut -d' ' -f3-)

if [ -n "$device" ]; then
    printf "ó°‚Ż %s" "$device"
else
    printf "ó°‚ł"
fi

#!/bin/sh
# sb-battery βÄî battery with contextual icons

# Dynamically find battery
for battery in /sys/class/power_supply/BAT* /sys/class/power_supply/CMB* /sys/class/power_supply/CWB*; do
    if [ -d "$battery" ]; then
        BATTERY_PATH="$battery"
        break
    fi
done

[ -z "$BATTERY_PATH" ] && exit 0

cap=$(cat "$BATTERY_PATH/capacity" 2>/dev/null)
status=$(cat "$BATTERY_PATH/status" 2>/dev/null)

[ -z "$cap" ] && exit 0

# Charging
if [ "$status" = "Charging" ]; then
    printf "σΑ²³ %s%%" "$cap"
    exit 0
fi

# Full
if [ "$status" = "Full" ]; then
    printf "σΑ¹Ι Full"
    exit 0
fi

# Discharging βÄî contextual icon
if [ "$cap" -ge 95 ]; then
    icon="σΑ¹Ι"
elif [ "$cap" -ge 85 ]; then
    icon="σΑ²²"
elif [ "$cap" -ge 75 ]; then
    icon="σΑ²¹"
elif [ "$cap" -ge 65 ]; then
    icon="σΑ²Ä"
elif [ "$cap" -ge 55 ]; then
    icon="σΑ¹Ω"
elif [ "$cap" -ge 45 ]; then
    icon="σΑ¹Ψ"
elif [ "$cap" -ge 35 ]; then
    icon="σΑ¹Ϋ"
elif [ "$cap" -ge 25 ]; then
    icon="σΑ¹Φ"
elif [ "$cap" -ge 15 ]; then
    icon="σΑ¹Μ"
elif [ "$cap" -ge 5 ]; then
    icon="σΑ¹Κ"
else
    icon="σΑ²é"
fi

printf "%s %s%%" "$icon" "$cap"
